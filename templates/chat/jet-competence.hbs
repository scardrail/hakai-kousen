<div class="hk-chat-card hk-jet-competence">
  <header class="hk-chat-header">
    <strong>{{actor.name}}</strong> — {{nomCompetence}}
  </header>
  <div class="hk-des">
    {{#each resultats as |valeur|}}
      <span class="hk-de {{#if (eq valeur 1)}}hk-de-echec{{else if (gte valeur ../difficulte)}}hk-de-succes{{/if}}">{{valeur}}</span>
    {{/each}}
  </div>
  <p class="hk-difficulte">{{localize "HK.Jet.Seuil"}} : {{difficulte}}+</p>
  {{#if reussite}}
    <p class="hk-resultat hk-reussite">{{localize "HK.Jet.Succes"}} ({{succes}})</p>
  {{else if echecCritique}}
    <p class="hk-resultat hk-echec-critique">{{localize "HK.Jet.Echec"}} critique !</p>
  {{else}}
    <p class="hk-resultat hk-echec">{{localize "HK.Jet.Echec"}}</p>
  {{/if}}
</div>
