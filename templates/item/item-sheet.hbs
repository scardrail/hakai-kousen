<div class="hk-sheet hk-item">
  {{{typeIconSprite}}}
  <header class="hk-band">
    <div class="hk-band-top">
      <img class="hk-portrait" src="{{item.img}}" data-action="editImage" data-edit="img" alt="{{item.name}}">
      <div class="hk-identite">
        <input class="hk-nom" type="text" name="name" value="{{item.name}}">
      </div>
      {{#if (eq item.type "attaque")}}{{typePill system.type}}{{/if}}
    </div>
  </header>

  {{#if (eq item.type "attaque")}}
    <section class="hk-grille-champs">
      <label>Type
        <select name="system.type">
          {{#each config.types as |label cle|}}<option value="{{cle}}" {{#if (eq ../system.type cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
        </select>
      </label>
      <label>Catégorie
        <select name="system.categorie">
          {{#each config.categoriesAttaque as |label cle|}}<option value="{{cle}}" {{#if (eq ../system.categorie cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
        </select>
      </label>
      <label>Portée
        <select name="system.portee">
          {{#each config.portees as |label cle|}}<option value="{{cle}}" {{#if (eq ../system.portee cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
        </select>
      </label>
      <label>Énergie <input type="number" name="system.energie" value="{{system.energie}}" min="0"></label>
      <label>Précision % <input type="number" name="system.precision" value="{{system.precision}}" min="1" max="100"></label>
      <label class="hk-checkbox">Ne peut être esquivée <input type="checkbox" name="system.toujoursTouche" {{#if system.toujoursTouche}}checked{{/if}}></label>
      <label>Dégâts (PB) <input type="number" name="system.degats" value="{{system.degats}}" min="0"></label>
    </section>

    <section class="hk-grille-champs">
      <label>Statut infligé
        <select name="system.statut.type">
          <option value=""></option>
          {{#each config.statuts as |label cle|}}<option value="{{cle}}" {{#if (eq ../system.statut.type cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
        </select>
      </label>
      <label>Chance % <input type="number" name="system.statut.chance" value="{{system.statut.chance}}" min="0" max="100"></label>
    </section>

    <section class="hk-modif-stats">
      <h3>Modificateurs de statistique</h3>
      <ul>
        {{#each system.modifStats as |modif index|}}
          <li data-index="{{index}}">
            <select name="system.modifStats.{{index}}.caracteristique">
              {{#each ../config.caracteristiques as |label cle|}}<option value="{{cle}}" {{#if (eq modif.caracteristique cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
            </select>
            <input type="number" name="system.modifStats.{{index}}.valeur" value="{{modif.valeur}}">
            <select name="system.modifStats.{{index}}.cible">
              <option value="cible" {{#if (eq modif.cible "cible")}}selected{{/if}}>{{localize "HK.Jet.Cible"}}</option>
              <option value="lanceur" {{#if (eq modif.cible "lanceur")}}selected{{/if}}>{{localize "HK.Jet.Lanceur"}}</option>
            </select>
            <a data-action="modifStatSupprimer"><i class="fa-solid fa-trash"></i></a>
          </li>
        {{/each}}
      </ul>
      <button type="button" class="hk-bouton-ajout" data-action="modifStatAjouter">+ Modificateur</button>
    </section>

    <label>Effets (texte libre)
      <prose-mirror name="system.effets" value="{{system.effets}}"></prose-mirror>
    </label>
  {{/if}}

  {{#if (eq item.type "talent")}}
    <label>Emplacement
      <select name="system.emplacement">
        <option value="premier" {{#if (eq system.emplacement "premier")}}selected{{/if}}>{{localize "HK.Talent.Premier"}}</option>
        <option value="second" {{#if (eq system.emplacement "second")}}selected{{/if}}>{{localize "HK.Talent.Second"}}</option>
        <option value="cache" {{#if (eq system.emplacement "cache")}}selected{{/if}}>{{localize "HK.Talent.Cache"}}</option>
      </select>
    </label>
    <label>Description <prose-mirror name="system.description" value="{{system.description}}"></prose-mirror></label>
  {{/if}}

  {{#if (or (eq item.type "competence") (eq item.type "connaissance"))}}
    <label>Score <input type="number" name="system.score" value="{{system.score}}" min="0" max="5"></label>
    <label>Rareté (Pokémon uniquement)
      <select name="system.rarete">
        <option value=""></option>
        {{#each config.rareteCompetence as |label cle|}}<option value="{{cle}}" {{#if (eq ../system.rarete cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
      </select>
    </label>
    <label>Description <prose-mirror name="system.description" value="{{system.description}}"></prose-mirror></label>
  {{/if}}

  {{#if (eq item.type "specialisation")}}
    <label>Compétence/Connaissance visée <input type="text" name="system.cible" value="{{system.cible}}"></label>
    <label>Description <prose-mirror name="system.description" value="{{system.description}}"></prose-mirror></label>
  {{/if}}

  {{#if (eq item.type "objet")}}
    <label>Catégorie
      <select name="system.categorie">
        {{#each config.categoriesObjet as |label cle|}}<option value="{{cle}}" {{#if (eq ../system.categorie cle)}}selected{{/if}}>{{localize label}}</option>{{/each}}
      </select>
    </label>
    <label>Prix <input type="number" name="system.prix" value="{{system.prix}}" min="0"></label>
    <label>Quantité <input type="number" name="system.quantite" value="{{system.quantite}}" min="0"></label>
    <label>Effet <prose-mirror name="system.effet" value="{{system.effet}}"></prose-mirror></label>
  {{/if}}

  {{#if (eq item.type "ct")}}
    <label>Numéro <input type="text" name="system.numero" value="{{system.numero}}"></label>
    <label>Attaque enseignée <input type="text" name="system.attaqueEnseignee" value="{{system.attaqueEnseignee}}"></label>
    <label>Prix <input type="number" name="system.prix" value="{{system.prix}}" min="0"></label>
    <label class="hk-checkbox">Usage unique <input type="checkbox" name="system.usageUnique" {{#if system.usageUnique}}checked{{/if}}></label>
    <label>Effet <prose-mirror name="system.effet" value="{{system.effet}}"></prose-mirror></label>
  {{/if}}

  {{#if (eq item.type "arme")}}
    <label>Catégorie
      <select name="system.categorie">
        <option value="melee" {{#if (eq system.categorie "melee")}}selected{{/if}}>{{localize "HK.Arme.Melee"}}</option>
        <option value="distance" {{#if (eq system.categorie "distance")}}selected{{/if}}>{{localize "HK.Arme.Distance"}}</option>
      </select>
    </label>
    <label>Dégâts <input type="text" name="system.degats" value="{{system.degats}}"></label>
    <label>Portée <input type="text" name="system.portee" value="{{system.portee}}"></label>
    <label>Notes <prose-mirror name="system.notes" value="{{system.notes}}"></prose-mirror></label>
  {{/if}}
</div>
